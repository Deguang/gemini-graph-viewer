{
  "manifest_version": 3,
  "name": "Gemini Graph (Flowchart) Split-Viewer",
  "version": "1.0.2",
  "description": "Professional split-view Mermaid diagram renderer for Google Gemini. Real-time preview, auto-fit, and export.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "*://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["lib/mermaid.min.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/mermaid.min.js"],
      "matches": ["*://gemini.google.com/*"]
    }
  ]
}
