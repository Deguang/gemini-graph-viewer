<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="arr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#c4baff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <clipPath id="cp">
      <rect x="0" y="0" width="512" height="512" rx="104"/>
    </clipPath>
  </defs>

  <!-- Background -->
  <rect x="0" y="0" width="512" height="512" rx="104" fill="#0d0c1a"/>

  <!-- Left pane -->
  <rect x="0" y="0" width="254" height="512" fill="#080714" clip-path="url(#cp)"/>
  <!-- Right pane -->
  <rect x="258" y="0" width="254" height="512" fill="#0b0a18" clip-path="url(#cp)"/>

  <!-- Divider -->
  <line x1="256" y1="18" x2="256" y2="494" stroke="#7b6fff" stroke-width="2.5" stroke-dasharray="7 5" stroke-opacity="0.8"/>

  <!-- 5 code lines, centered in left pane (center x=128) -->
  <rect x="72"  y="186" width="112" height="16" rx="8" fill="#b8b0ff"/>
  <rect x="88"  y="216" width="80"  height="16" rx="8" fill="#6056b0"/>
  <rect x="80"  y="246" width="96"  height="16" rx="8" fill="#6056b0"/>
  <rect x="92"  y="276" width="72"  height="16" rx="8" fill="#6056b0" opacity="0.8"/>
  <rect x="84"  y="306" width="88"  height="16" rx="8" fill="#6056b0" opacity="0.6"/>

  <!-- 3 flowchart nodes, centered in right pane (center x=384) -->
  <rect x="314" y="174" width="140" height="46" rx="12" fill="#7c6fff" stroke="#c4baff" stroke-width="2.5"/>
  <line x1="384" y1="220" x2="384" y2="242" stroke="#c4baff" stroke-width="3" marker-end="url(#arr)"/>
  <rect x="314" y="244" width="140" height="46" rx="12" fill="#302b6e" stroke="#7c6fff" stroke-width="2.5"/>
  <line x1="384" y1="290" x2="384" y2="312" stroke="#c4baff" stroke-width="3" marker-end="url(#arr)"/>
  <rect x="314" y="314" width="140" height="46" rx="12" fill="#7c6fff" stroke="#c4baff" stroke-width="2.5"/>

  <!-- Outer border -->
  <rect x="0" y="0" width="512" height="512" rx="104" fill="none" stroke="#9d94ff" stroke-width="2" stroke-opacity="0.5"/>
</svg>
